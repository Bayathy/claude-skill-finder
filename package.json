{
  "name": "claude-skill-finder",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "claude-skill-finder": "./src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/cli.ts",
    "start": "bun src/cli.ts",
