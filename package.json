    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "typecheck": "tsc --noEmit && tsc --noEmit -p public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "typescript": "5.9.3"
  }
}
